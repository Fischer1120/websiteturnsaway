---
type Row = {
  label: string;
  value?: string | number;
};

type Props = {
  title: string;
  rows: Row[];
};

const { title, rows } = Astro.props;
---

<aside class="sidecar">
  <h2>{title}</h2>
  <div class="meta-list">
    {rows.filter((row) => row.value !== undefined && row.value !== "").map((row) => (
      <div class="meta-row">
        <span class="meta-label">{row.label}</span>
        <strong class="meta-value">{row.value}</strong>
      </div>
    ))}
  </div>
</aside>
