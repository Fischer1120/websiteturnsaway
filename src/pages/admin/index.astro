---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
---

<BaseLayout title="后台管理 - Website Turns Away">
  <div class="layout-grid">
    <RouteMatrix />
    <main class="content-stack">
      <section class="panel dark admin-console" id="admin-root">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Admin Console</p>
            <h1>后台管理</h1>
          </div>
          <p>输入管理密码后，可以上传和管理文章、图片与分组。密码只保存在当前浏览器会话。</p>
        </div>
        <div class="empty-state public-loading">
          <p class="system-text">BOOTING / ADMIN MODULE</p>
        </div>
      </section>
    </main>
  </div>
  <script is:inline src="/assets/admin.js" defer></script>
</BaseLayout>
