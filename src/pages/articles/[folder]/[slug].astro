---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import PublicContentShell from "@/components/PublicContentShell.astro";
import { getArticles } from "@/lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { folder: article.folder, slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={`${article.title} - Website Turns Away`} description={article.summary}>
  <div class="layout-grid">
    <RouteMatrix />
    <PublicContentShell
      kind="articles"
      eyebrow={`Article Record / ${article.folder}/${article.slug}`}
      title={article.title}
      description={article.summary}
    />
  </div>
</BaseLayout>
