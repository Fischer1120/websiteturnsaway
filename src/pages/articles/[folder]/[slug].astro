---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import MetadataSidecar from "@/components/MetadataSidecar.astro";
import { formatDate, getArticles, getFolderLabel } from "@/lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { folder: article.folder, slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={`${article.title} - Website Turns Away`} description={article.summary}>
  <div class="layout-grid">
    <RouteMatrix />
    <main class="content-stack">
      <article class="panel article-detail">
        <div class="article-prose">
          <p class="eyebrow">Article Record / {article.folder}/{article.slug}</p>
          <h1>{article.title}</h1>
          <p class="subtitle">{article.subtitle}</p>
          <div class="article-body" set:html={article.html} />
        </div>
        <MetadataSidecar
          title="Article sidecar"
          rows={[
            { label: "Folder", value: getFolderLabel(article.folder) },
            { label: "Slug", value: article.slug },
            { label: "Published", value: formatDate(article.publishedAt, true) },
            { label: "Updated", value: formatDate(article.updatedAt, true) },
            { label: "Headings", value: article.headings.join(" / ") },
            { label: "R2 Key", value: `articles/${article.folder}/${article.slug}/index.md` },
          ]}
        />
      </article>
    </main>
  </div>
</BaseLayout>
