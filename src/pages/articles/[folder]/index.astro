---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import PublicContentShell from "@/components/PublicContentShell.astro";
import { getArticleFolders } from "@/lib/content";

export function getStaticPaths() {
  return getArticleFolders().map((folder) => ({
    params: { folder: folder.slug },
    props: { folder },
  }));
}

const { folder } = Astro.props;
---

<BaseLayout title={`${folder.label} - 文章文件夹`}>
  <div class="layout-grid">
    <RouteMatrix />
    <PublicContentShell
      kind="articles"
      eyebrow={`/articles/${folder.slug}`}
      title={folder.label}
      description={folder.description}
    />
  </div>
</BaseLayout>
