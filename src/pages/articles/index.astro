---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import PublicContentShell from "@/components/PublicContentShell.astro";
---

<BaseLayout title="文章栏目 - Website Turns Away">
  <div class="layout-grid">
    <RouteMatrix />
    <PublicContentShell
      kind="articles"
      eyebrow="Articles / Live Index"
      title="文章栏目"
      description="文章以 folder 和 slug 建立稳定地址；后台保存后会通过 API 立即进入这里。"
    />
  </div>
</BaseLayout>
