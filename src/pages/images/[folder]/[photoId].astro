---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import PublicContentShell from "@/components/PublicContentShell.astro";
import { getPhotos } from "@/lib/content";

export function getStaticPaths() {
  return getPhotos().map((photo) => ({
    params: { folder: photo.folder, photoId: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
---

<BaseLayout title={`${photo.title} - Website Turns Away`} description={photo.description}>
  <div class="layout-grid">
    <RouteMatrix />
    <PublicContentShell
      kind="images"
      eyebrow={`Photo Record / ${photo.folder}/${photo.id}`}
      title={photo.title}
      description={photo.description}
    />
  </div>
</BaseLayout>
