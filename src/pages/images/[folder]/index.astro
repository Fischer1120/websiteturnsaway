---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import RecordCard from "@/components/RecordCard.astro";
import { formatDate, getPhotoFolders } from "@/lib/content";

export function getStaticPaths() {
  return getPhotoFolders().map((folder) => ({
    params: { folder: folder.slug },
    props: { folder },
  }));
}

const { folder } = Astro.props;
---

<BaseLayout title={`${folder.label} - 图片文件夹`}>
  <div class="layout-grid">
    <RouteMatrix />
    <main class="content-stack">
      <section class="panel dark">
        <div class="section-heading">
          <div>
            <p class="eyebrow">/images/{folder.slug}</p>
            <h1>{folder.label}</h1>
          </div>
          <p>{folder.description}</p>
        </div>
        <div class="record-grid">
          {folder.items.map((photo) => (
            <RecordCard
              href={`/images/${photo.folder}/${photo.id}`}
              title={photo.title}
              summary={`${formatDate(photo.capturedAt, true)} / ${photo.location.label} / ${photo.description}`}
              image={photo.thumbUrl}
              date={photo.capturedAt}
              folder={photo.folder}
              kind="photo"
            />
          ))}
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
