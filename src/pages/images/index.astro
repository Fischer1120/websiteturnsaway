---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RouteMatrix from "@/components/RouteMatrix.astro";
import PublicContentShell from "@/components/PublicContentShell.astro";
---

<BaseLayout title="图片栏目 - Website Turns Away">
  <div class="layout-grid">
    <RouteMatrix />
    <PublicContentShell
      kind="images"
      eyebrow="Images / Live Metadata Index"
      title="图片栏目"
      description="图片按相册文件夹组织；后台上传后会通过 R2 和 API 立即进入这里。"
    />
  </div>
</BaseLayout>
